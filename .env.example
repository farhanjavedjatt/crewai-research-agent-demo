# --- Copy this file to .env and fill in real values ------------------------
# Supabase (service role key lives server-side only; never expose in a browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# LLM provider. CrewAI delegates to LiteLLM, so any supported model works.
# Examples:
#   openai/gpt-4o-mini            (default, cheapest good option)
#   openai/gpt-4o
#   anthropic/claude-haiku-4-5-20251001
#   anthropic/claude-sonnet-4-6
MODEL_NAME=openai/gpt-4o-mini

OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# Web-search integration (optional).
# Leave SERPER_API_KEY blank to use the zero-config DuckDuckGo fallback.
# Get a free key at https://serper.dev (2,500 searches/month free tier).
SERPER_API_KEY=

# Runtime
LOG_LEVEL=INFO
# Max number of past sessions surfaced in the Streamlit sidebar
HISTORY_LIMIT=25
