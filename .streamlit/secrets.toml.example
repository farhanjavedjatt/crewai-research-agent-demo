# Template for Streamlit Community Cloud secrets.
#
# On SCC: open your app → ⋯ → Settings → Secrets, paste the contents of this
# file (with real values), and save. Streamlit reloads the app automatically.
# `streamlit_app.py` promotes these into `os.environ` so `pydantic-settings`
# picks them up exactly as it does from `.env` locally.
#
# DO NOT commit the real `secrets.toml` — it is .gitignored.

NEXT_PUBLIC_SUPABASE_URL = "https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY = "your-anon-key"
SUPABASE_SERVICE_ROLE_KEY = "your-service-role-key"

MODEL_NAME = "openai/gpt-4o-mini"
OPENAI_API_KEY = "sk-..."
# ANTHROPIC_API_KEY = "sk-ant-..."

# Optional: enables SerperDevTool instead of the DuckDuckGo fallback.
SERPER_API_KEY = ""

LOG_LEVEL = "INFO"
HISTORY_LIMIT = 25
